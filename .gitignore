# =============================
# Stopfmaschine .gitignore
# =============================

# --- Arduino / PlatformIO ---
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
build/
*.hex
*.elf
*.bin
# Ausnahme: der eingecheckte Prebuilt-Hex, den die App zum Nano-Flashen nutzt
!firmware/nano/firmware.hex

# Arduino IDE
*.ino.with_bootloader.*
*.ino.eep
*.ino.hex
.build/

# --- Python / Pi Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
.env
.env.local
.env.*.local

# Distribution / packaging
.eggs/
*.egg-info/
*.egg
dist/
build/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Pytest / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# SQLite (lokale DBs auf Pi)
*.db
*.sqlite
*.sqlite3

# --- Mobile App ---

# Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
android/.gradle/
android/local.properties
android/app/debug
android/app/profile
android/app/release
*.iml

# Swift / Xcode
*.xcuserstate
xcuserdata/
DerivedData/
*.moved-aside
*.xccheckout
*.xcscmblueprint
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
Pods/

# React Native
node_modules/
npm-debug.log
yarn-error.log

# .NET MAUI
bin/
obj/
*.suo
*.user

# --- CAD / Mechanik ---

# Onshape exports (große Binärdateien meiden)
*.step.bak
*.iges.bak
exports/temp/

# Lokale 3D-Druck Slices
*.gcode
*.stl.bak

# Fusion-Skript Dosiertrommel (lokal, nicht ins Repo)
cad/scripts/dosiertrommel/

# --- IDE / Editor ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json.example
# Auch verschachtelte .vscode-Ordner (z.B. in cad/scripts/*) ignorieren
**/.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# LibreOffice / Office Lockfiles
.~lock.*#
~$*

# --- Claude Code ---
.claude/auto-memory/
.claude/cache/
.claude/sessions/

# --- Logs & temporäre Dateien ---
*.log
logs/
tmp/
temp/

# --- Sensible Daten ---
secrets.json
*.key
*.pem
config.local.*
wifi_credentials.txt
